# Copy this file to .env for Docker Compose. Keep .env local and ignored.
# Generate real values locally; do not commit them.

JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=
APPLICATION_INTERNAL_API_TOKEN=
JHIPSTER_CONTROL_CENTER_PASSWORD=
GRAFANA_ADMIN_PASSWORD=
SERVER_SSL_KEY_STORE_PASSWORD=

# Optional local/CI values.
SONAR_LOGIN=
SONAR_PASSWORD=
GATEWAY_DB_PASSWORD=
USER_SERVICE_DB_PASSWORD=
PROJECT_SERVICE_DB_PASSWORD=
BILLING_SERVICE_DB_PASSWORD=
NOTIFICATION_SERVICE_DB_PASSWORD=

# Optional production infrastructure overrides.
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://zipkin:9411/api/v2/spans
SPRING_CLOUD_CONSUL_HOST=consul
SPRING_CLOUD_CONSUL_PORT=8500
SPRING_MAIL_HOST=mail
SPRING_MAIL_PORT=25
JHIPSTER_LOGGING_LOGSTASH_HOST=logstash
JHIPSTER_LOGGING_LOGSTASH_PORT=5000
