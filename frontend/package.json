{
  "name": "nexaflow-frontend",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "description": "NexaFlow standalone Angular frontend",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist/",
    "start": "ng serve --hmr",
    "start:tls": "ng serve --ssl",
    "serve": "npm run start --",
    "build": "npm run build:prod",
    "build:dev": "ng build --configuration development",
    "build:prod": "ng build --configuration production",
    "build:watch": "npm run build:dev -- --watch",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "pretest": "npm run lint",
    "test": "ng test --coverage",
    "test:watch": "npm run test -- --watch",
    "prettier:check": "prettier --check \"{,.blueprint/**/,src/**/,build-plugins/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,html,css,scss}\"",
    "prettier:format": "prettier --write \"{,.blueprint/**/,src/**/,build-plugins/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,html,css,scss}\"",
    "docker:build": "docker build -t nexaflow-frontend ."
  },
  "dependencies": {
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/forms": "21.2.14",
    "@angular/localize": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/router": "21.2.14",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@ng-bootstrap/ng-bootstrap": "20.0.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@primeuix/themes": "^2.0.3",
    "bootstrap": "5.3.8",
    "dayjs": "1.11.21",
    "ngx-infinite-scroll": "21.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-builders/custom-esbuild": "21.0.3",
    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.14",
    "@angular/service-worker": "21.2.14",
    "@eslint/js": "10.0.1",
    "@types/folder-hash": "4.0.4",
    "@types/node": "22.19.19",
    "@vitest/coverage-v8": "4.1.7",
    "angular-eslint": "21.4.0",
    "browser-sync": "3.0.4",
    "concurrently": "9.2.1",
    "deepmerge": "4.3.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "folder-hash": "4.1.3",
    "generator-jhipster": "9.1.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "prettier-plugin-java": "2.9.6",
    "prettier-plugin-packagejson": "3.0.2",
    "rimraf": "6.1.3",
    "swagger-ui-dist": "5.32.6",
    "tinyglobby": "0.2.16",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7",
    "vitest-sonar-reporter": "3.0.0",
    "wait-on": "9.0.10"
  },
  "engines": {
    "node": ">=24.16.0"
  }
}
